{
  "id": "subdomain-finder",
  "name": "Subdomain Finder",
  "version": "1.0.0",
  "description": "Discover subdomains of a domain.",
  "long_description": "Discover subdomains of a domain.",
  "category": "recon",
  "author": {
    "name": "SecuScan Contributors",
    "email": "dev@secuscan.local"
  },
  "license": "MIT",
  "icon": "🔎",
  "engine": {
    "type": "cli",
    "binary": "subfinder"
  },
  "command_template": [
    "subfinder",
    "-d",
    "{target}",
    "-silent"
  ],
  "fields": [
    {
      "id": "target",
      "label": "Root Domain",
      "type": "string",
      "required": true,
      "placeholder": "secuscan.in"
    }
  ],
  "presets": {
    "default": {}
  },
  "output": {
    "format": "text",
    "parser": "custom"
  },
  "safety": {
    "level": "safe",
    "requires_consent": false,
    "rate_limit": {
      "max_per_hour": 20,
      "max_concurrent": 1
    }
  },
  "dependencies": {
    "binaries": [
      "subfinder"
    ],
    "python_packages": [],
    "system_packages": []
  },
  "checksum": "8d8753e65ebf84e28cdff95b6c07b5501884e94e1df7092b759f7bc432be2045"
}