{
  "id": "sniper",
  "name": "Sniper: Auto-Exploiter",
  "version": "1.0.0",
  "description": "Validate critical CVEs by automatic exploitation.",
  "long_description": "Validate critical CVEs by automatic exploitation.",
  "category": "exploit",
  "author": {
    "name": "SecuScan Contributors",
    "email": "dev@secuscan.local"
  },
  "license": "MIT",
  "icon": "🛠️",
  "engine": {
    "type": "cli",
    "binary": "python3"
  },
  "command_template": [
    "python3",
    "-c",
    "import sys;print('Sniper simulation started');print('target='+sys.argv[1]);print('status=planned_exploit_path')",
    "{target}"
  ],
  "fields": [
    {
      "id": "target",
      "label": "Target",
      "type": "string",
      "required": true,
      "placeholder": "secuscan.in"
    }
  ],
  "presets": {
    "default": {}
  },
  "output": {
    "format": "text",
    "parser": "custom"
  },
  "safety": {
    "level": "exploit",
    "requires_consent": true,
    "consent_message": "Sniper models exploit flows. Use only with explicit authorization.",
    "rate_limit": {
      "max_per_hour": 20,
      "max_concurrent": 1
    }
  },
  "dependencies": {
    "binaries": [
      "python3"
    ],
    "python_packages": [],
    "system_packages": []
  },
  "checksum": "a03c101f7c722c9194bfd711ef68a3deb73a00452b517045846bf9e3ddf3a4d7"
}