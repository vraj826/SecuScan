{
  "id": "hashcat",
  "name": "Password Recovery Audit",
  "version": "1.0.0",
  "description": "Password recovery and hash audit workflow.",
  "long_description": "Runs Hashcat in controlled audit mode to evaluate password strength against authorized hash sets.",
  "category": "expert",
  "author": {
    "name": "SecuScan Contributors",
    "email": "dev@secuscan.local"
  },
  "license": "MIT",
  "icon": "⚡",
  "engine": {
    "type": "cli",
    "binary": "hashcat"
  },
  "command_template": [
    "hashcat",
    "-m",
    "{hash_type}",
    "-a",
    "{attack_mode}",
    "{target}",
    "--if:wordlist:then:{wordlist}",
    "--if:session_name:then:--session",
    "--if:session_name:then:{session_name}",
    "--quiet"
  ],
  "fields": [
    {
      "id": "target",
      "label": "Hash File Path",
      "type": "string",
      "required": true,
      "placeholder": "/tmp/hashes.txt"
    },
    {
      "id": "hash_type",
      "label": "Hash Type (Mode)",
      "type": "integer",
      "required": false,
      "default": 0,
      "help": "Example: 0=MD5, 1000=NTLM"
    },
    {
      "id": "attack_mode",
      "label": "Attack Mode",
      "type": "integer",
      "required": false,
      "default": 0,
      "help": "0=dictionary, 3=mask"
    },
    {
      "id": "wordlist",
      "label": "Wordlist Path",
      "type": "string",
      "required": false,
      "placeholder": "/usr/share/wordlists/rockyou.txt"
    },
    {
      "id": "session_name",
      "label": "Session Name",
      "type": "string",
      "required": false,
      "default": ""
    }
  ],
  "presets": {
    "md5_dictionary": {
      "hash_type": 0,
      "attack_mode": 0
    },
    "ntlm_dictionary": {
      "hash_type": 1000,
      "attack_mode": 0
    }
  },
  "output": {
    "format": "text",
    "parser": "custom"
  },
  "safety": {
    "level": "exploit",
    "requires_consent": true,
    "consent_message": "Hashcat performs offensive-style password recovery. Use only for authorized assessments.",
    "rate_limit": {
      "max_per_hour": 5,
      "max_concurrent": 1
    }
  },
  "dependencies": {
    "binaries": [
      "hashcat"
    ],
    "python_packages": [],
    "system_packages": []
  },
  "checksum": "819535b40fb284821022924b2f4c261ceb3084b38b3f3f17f4601b6ea528d862"
}