{
  "id": "metasploit",
  "name": "Exploitation Connector",
  "version": "1.0.0",
  "description": "Metasploit connector for controlled exploit-module execution.",
  "long_description": "Runs a selected Metasploit module in scripted mode for authorized exploitation validation workflows.",
  "category": "expert",
  "author": {
    "name": "SecuScan Contributors",
    "email": "dev@secuscan.local"
  },
  "license": "MIT",
  "icon": "🚀",
  "engine": {
    "type": "cli",
    "binary": "msfconsole"
  },
  "command_template": [
    "msfconsole",
    "-q",
    "-x",
    "use {module}; set RHOSTS {target}; set PAYLOAD {payload}; run; exit"
  ],
  "fields": [
    {
      "id": "target",
      "label": "Remote Host",
      "type": "string",
      "required": true,
      "placeholder": "10.10.10.10"
    },
    {
      "id": "module",
      "label": "Metasploit Module",
      "type": "string",
      "required": true,
      "default": "exploit/multi/handler"
    },
    {
      "id": "payload",
      "label": "Payload",
      "type": "string",
      "required": false,
      "default": "generic/shell_reverse_tcp"
    }
  ],
  "presets": {
    "handler": {
      "module": "exploit/multi/handler",
      "payload": "generic/shell_reverse_tcp"
    }
  },
  "output": {
    "format": "text",
    "parser": "custom"
  },
  "safety": {
    "level": "exploit",
    "requires_consent": true,
    "consent_message": "Metasploit can launch exploit payloads. Explicit authorization is mandatory.",
    "rate_limit": {
      "max_per_hour": 3,
      "max_concurrent": 1
    }
  },
  "dependencies": {
    "binaries": [
      "msfconsole"
    ],
    "python_packages": [],
    "system_packages": []
  },
  "checksum": "b9a6ba683c890ebd466a2e0f303493a3f625272dfa29cda52af4349ebb2e5fef"
}