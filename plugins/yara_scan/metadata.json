{
  "id": "yara_scan",
  "name": "Binary Signature Scan",
  "version": "1.0.0",
  "description": "Binary and file-system signature matching with YARA rules.",
  "long_description": "Runs recursive YARA scans against binaries, folders, or artifacts and reports matched signatures.",
  "category": "forensics",
  "author": {
    "name": "SecuScan Contributors",
    "email": "dev@secuscan.local"
  },
  "license": "MIT",
  "icon": "🔬",
  "engine": {
    "type": "cli",
    "binary": "yara"
  },
  "command_template": [
    "yara",
    "-r",
    "{rules}",
    "{target}",
    "--if:print_strings:then:-s"
  ],
  "fields": [
    {
      "id": "target",
      "label": "Target File/Directory",
      "type": "string",
      "required": true,
      "placeholder": "/tmp/suspicious.bin",
      "help": "Path to file or directory to scan."
    },
    {
      "id": "rules",
      "label": "YARA Rules Path",
      "type": "string",
      "required": true,
      "placeholder": "/opt/rules/malware.yar"
    },
    {
      "id": "print_strings",
      "label": "Print Matching Strings",
      "type": "boolean",
      "required": false,
      "default": false
    }
  ],
  "presets": {
    "default": {
      "print_strings": false
    }
  },
  "output": {
    "format": "text",
    "parser": "custom"
  },
  "safety": {
    "level": "intrusive",
    "requires_consent": true,
    "consent_message": "YARA can process sensitive binaries/artifacts. Ensure approved forensic scope.",
    "rate_limit": {
      "max_per_hour": 20,
      "max_concurrent": 1
    }
  },
  "dependencies": {
    "binaries": [
      "yara"
    ],
    "python_packages": [],
    "system_packages": []
  },
  "checksum": "a86b7e27c6f1f46889e6f0b93ad368e676ac0654748920d4ef40d16481ce6e72"
}