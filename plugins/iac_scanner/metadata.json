{
  "id": "iac_scanner",
  "name": "IaC Scanner (Checkov)",
  "version": "1.0.0",
  "description": "Analyze Terraform and CloudFormation code for flaws.",
  "long_description": "Analyze Terraform and CloudFormation code for flaws.",
  "category": "vulnerability",
  "author": {
    "name": "SecuScan Contributors",
    "email": "dev@secuscan.local"
  },
  "license": "MIT",
  "icon": "🛠️",
  "engine": {
    "type": "cli",
    "binary": "python3"
  },
  "command_template": [
    "python3",
    "-c",
    "import sys,pathlib;root=pathlib.Path(sys.argv[1]);print('iac_scan_root='+str(root));cnt=sum(1 for p in root.rglob('*') if p.suffix in ('.tf','.yaml','.yml','.json'));print('candidate_iac_files='+str(cnt))",
    "{target}"
  ],
  "fields": [
    {
      "id": "target",
      "label": "IaC Directory",
      "type": "string",
      "required": true,
      "placeholder": "."
    }
  ],
  "presets": {
    "default": {
      "target": "."
    }
  },
  "output": {
    "format": "text",
    "parser": "custom"
  },
  "safety": {
    "level": "safe",
    "requires_consent": false,
    "rate_limit": {
      "max_per_hour": 20,
      "max_concurrent": 1
    }
  },
  "dependencies": {
    "binaries": [
      "python3"
    ],
    "python_packages": [],
    "system_packages": []
  },
  "checksum": "86d42936b4c1f417e89d8e3c1e23e023057d52ef6d68f7a021c6e0bd82623bbf"
}