{
  "id": "joomscan",
  "name": "Joomla Security Scan",
  "version": "1.0.0",
  "description": "Joomla security scanner for version and common weakness discovery.",
  "long_description": "Runs JoomScan against a Joomla target and extracts vulnerable patterns and interesting disclosures.",
  "category": "vulnerability",
  "author": {
    "name": "SecuScan Contributors",
    "email": "dev@secuscan.local"
  },
  "license": "MIT",
  "icon": "🏷️",
  "engine": {
    "type": "cli",
    "binary": "joomscan"
  },
  "command_template": [
    "joomscan",
    "-u",
    "{target}"
  ],
  "fields": [
    {
      "id": "target",
      "label": "Target URL",
      "type": "string",
      "required": true,
      "placeholder": "https://joomla.secuscan.in",
      "validation": {
        "pattern": "^https?://",
        "message": "Must be a valid HTTP(S) URL"
      }
    }
  ],
  "presets": {
    "default": {}
  },
  "output": {
    "format": "text",
    "parser": "custom"
  },
  "safety": {
    "level": "intrusive",
    "requires_consent": true,
    "consent_message": "JoomScan runs active checks and should only be used on authorized targets.",
    "rate_limit": {
      "max_per_hour": 10,
      "max_concurrent": 1
    }
  },
  "dependencies": {
    "binaries": [
      "joomscan"
    ],
    "python_packages": [],
    "system_packages": []
  },
  "checksum": "a7665b39dea70ef5307a1b9e45cd5a6d8b5ced9e4e72c53400ebbad9aace66b0"
}