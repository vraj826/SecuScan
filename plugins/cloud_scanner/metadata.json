{
  "id": "cloud_scanner",
  "name": "Cloud Scanner",
  "version": "1.0.0",
  "description": "Cloud infrastructure security (AWS/GCP/Azure).",
  "long_description": "Cloud infrastructure security (AWS/GCP/Azure).",
  "category": "vulnerability",
  "author": {
    "name": "SecuScan Contributors",
    "email": "dev@secuscan.local"
  },
  "license": "MIT",
  "icon": "🛠️",
  "engine": {
    "type": "cli",
    "binary": "python3"
  },
  "command_template": [
    "python3",
    "-c",
    "import sys;print('Cloud scan baseline checks');print('target='+sys.argv[1]);print('providers=aws,gcp,azure')",
    "{target}"
  ],
  "fields": [
    {
      "id": "target",
      "label": "Account/Project Identifier",
      "type": "string",
      "required": true,
      "placeholder": "org-example"
    }
  ],
  "presets": {
    "default": {}
  },
  "output": {
    "format": "text",
    "parser": "custom"
  },
  "safety": {
    "level": "intrusive",
    "requires_consent": true,
    "consent_message": "Cloud scanning requires explicit account-level authorization.",
    "rate_limit": {
      "max_per_hour": 20,
      "max_concurrent": 1
    }
  },
  "dependencies": {
    "binaries": [
      "python3"
    ],
    "python_packages": [],
    "system_packages": []
  },
  "checksum": "c8d56d5acb054b8be673a587481554ffa12688b2e5558e5c85eff6ef033686ba"
}