{
  "id": "sqlmap",
  "name": "SQL Injection Testing",
  "version": "1.0.0",
  "description": "Automatic SQL injection and database takeover tool",
  "long_description": "SQLMap is an open source penetration testing tool that automates the process of detecting and exploiting SQL injection flaws and taking over of database servers.",
  "category": "web",
  "author": {
    "name": "SecuScan Contributors",
    "email": "dev@secuscan.local"
  },
  "license": "GPLv2",
  "icon": "💉",
  "engine": {
    "type": "cli",
    "binary": "sqlmap"
  },
  "docker_image": "sqlmap/sqlmap",
  "command_template": [
    "sqlmap",
    "-u",
    "{url}",
    "--batch",
    "--if:level:then:--level",
    "--if:level:then:{level}",
    "--if:risk:then:--risk",
    "--if:risk:then:{risk}",
    "--if:dbs:then:--dbs"
  ],
  "fields": [
    {
      "id": "url",
      "label": "Target URL",
      "type": "string",
      "required": true,
      "placeholder": "http://secuscan.in/vuln.php?id=1",
      "validation": {
        "pattern": "^https?://",
        "message": "Must be a valid HTTP/HTTPS URL"
      },
      "help": "The vulnerable URL parameter to test"
    },
    {
      "id": "preset",
      "label": "Scan Preset",
      "type": "select",
      "required": false,
      "default": "quick",
      "options": [
        {
          "value": "quick",
          "label": "Quick (Level 1, Risk 1)"
        },
        {
          "value": "aggressive",
          "label": "Aggressive (Level 5, Risk 3)"
        }
      ],
      "help": "Predefined scan configuration profiles"
    },
    {
      "id": "level",
      "label": "Test Level (1-5)",
      "type": "integer",
      "required": false,
      "default": 1,
      "help": "Level of tests to perform (1-5, default 1)"
    },
    {
      "id": "risk",
      "label": "Test Risk (1-3)",
      "type": "integer",
      "required": false,
      "default": 1,
      "help": "Risk of tests to perform (1-3, default 1)"
    },
    {
      "id": "dbs",
      "label": "Enumerate Databases",
      "type": "boolean",
      "required": false,
      "default": false,
      "help": "Attempt to enumerate the DBMS databases"
    }
  ],
  "presets": {
    "quick": {
      "level": 1,
      "risk": 1,
      "dbs": false
    },
    "aggressive": {
      "level": 5,
      "risk": 3,
      "dbs": true
    }
  },
  "output": {
    "format": "text",
    "parser": "custom"
  },
  "safety": {
    "level": "exploit",
    "requires_consent": true,
    "consent_message": "SQL injection attacks are highly intrusive and modify database states. ONLY run this against systems you own.",
    "allowed_targets": [
      "127.0.0.1",
      "192.168.*.*",
      "10.*.*.*",
      "172.16.*.*"
    ],
    "rate_limit": {
      "max_per_hour": 5,
      "max_concurrent": 1
    }
  },
  "learning": {
    "difficulty": "advanced",
    "estimated_duration": "5-30 minutes",
    "tutorial_url": "https://docs.secuscan.local/plugins/sqlmap"
  },
  "dependencies": {
    "binaries": [],
    "python_packages": [],
    "system_packages": []
  },
  "checksum": "eadbb87b8121c94adf64bf13a7ad8fc8089575f75a2fabf8bc30ce9d6aa2bda8"
}