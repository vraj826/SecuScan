{
  "id": "urlfinder",
  "name": "urlfinder",
  "version": "1.0.0",
  "description": "Passive historical URL collection.",
  "long_description": "Passive historical URL collection.",
  "category": "recon",
  "author": {
    "name": "SecuScan Contributors",
    "email": "dev@secuscan.local"
  },
  "license": "MIT",
  "icon": "🔎",
  "engine": {
    "type": "cli",
    "binary": "urlfinder"
  },
  "command_template": [
    "urlfinder",
    "-d",
    "{target}",
    "-silent"
  ],
  "fields": [
    {
      "id": "target",
      "label": "Domain",
      "type": "string",
      "required": true,
      "placeholder": "secuscan.in"
    }
  ],
  "presets": {
    "default": {}
  },
  "output": {
    "format": "text",
    "parser": "custom"
  },
  "safety": {
    "level": "safe",
    "requires_consent": false,
    "rate_limit": {
      "max_per_hour": 20,
      "max_concurrent": 1
    }
  },
  "dependencies": {
    "binaries": [
      "urlfinder"
    ],
    "python_packages": [],
    "system_packages": []
  },
